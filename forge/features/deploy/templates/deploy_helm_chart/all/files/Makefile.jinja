# Deployment helpers for {{ topology.project_slug }} (generated by forge).
# The Helm chart under deploy/helm/ is the source of truth; raw manifests in
# deploy/k8s/ are derived from it (never hand-edit deploy/k8s/rendered.yaml).

RELEASE ?= {{ topology.project_slug | replace("_", "-") }}
NAMESPACE ?= default
CHART := deploy/helm
VALUES ?= deploy/helm/values-prod.yaml

.PHONY: help compose-up compose-down helm-lint helm-template k8s-manifests helm-install helm-uninstall

help:
	@grep -E "^[a-zA-Z_-]+:.*?#" $(MAKEFILE_LIST) | awk 'BEGIN{FS=":.*?# "}{printf "  %-16s %s\n", $$1, $$2}'

compose-up: ## Boot the full local stack (docker compose)
	docker compose up --build -d

compose-down: ## Stop the local stack
	docker compose down

helm-lint: ## Lint the Helm chart
	helm lint $(CHART)

helm-template: ## Render the chart to stdout
	helm template $(RELEASE) $(CHART)

k8s-manifests: ## Render raw manifests to deploy/k8s/rendered.yaml (derived from the chart)
	@mkdir -p deploy/k8s
	helm template $(RELEASE) $(CHART) > deploy/k8s/rendered.yaml
	@echo "Wrote deploy/k8s/rendered.yaml"

helm-install: ## Install/upgrade the release (uses $(VALUES) if present)
	helm upgrade --install $(RELEASE) $(CHART) --namespace $(NAMESPACE) --create-namespace $$( [ -f $(VALUES) ] && echo "-f $(VALUES)" )

helm-uninstall: ## Remove the release
	helm uninstall $(RELEASE) --namespace $(NAMESPACE)
