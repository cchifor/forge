{# RFC-009 service-registration macro for Python / Dishka backends.

Renders a dishka.Provider subclass that wires `service.type` into the
container at the requested scope. The fragment supplies the
implementation class; this macro emits only the registration boilerplate.

Required `service` keys:
  - name           — snake_case identifier
  - type           — Python class name (must be importable by the fragment's
                     existing `files/` tree)
  - import_path    — dotted module path of the implementation class
  - scope          — singleton | request | transient
  - dependencies   — list of other registered service `name`s; injected by
                     parameter to the provider method
  - config_key     — dotted AppConfig path; injected from `Settings`

Optional:
  - startup        — when true, eager-instantiate at app boot
  - shutdown_hook  — method called on graceful shutdown
#}
{%- macro provider(service) -%}
from dishka import Provider, Scope, provide
from {{ service.import_path }} import {{ service.type }}
{% if service.config_key -%}
from app.core.config import settings
{%- endif %}


class {{ service.type }}Provider(Provider):
    """Auto-generated by RFC-009 service-registration macro."""

    scope = Scope.{{ "APP" if service.scope == "singleton" else "REQUEST" }}

    @provide
    {%- if service.scope == "singleton" %}
    def {{ service.name }}(self
        {%- for dep in service.dependencies %}, {{ dep }}: object{% endfor -%}
    ) -> {{ service.type }}:
        return {{ service.type }}(
            {%- if service.config_key %}config=settings.{{ service.config_key }},{% endif -%}
            {%- for dep in service.dependencies %}{{ dep }}={{ dep }},{% endfor -%}
        )
    {%- else %}
    def {{ service.name }}(self) -> {{ service.type }}:
        return {{ service.type }}(
            {%- if service.config_key %}config=settings.{{ service.config_key }}{% endif -%}
        )
    {%- endif %}
{%- endmacro %}
