import Fastify from "fastify";
import cors from "@fastify/cors";
import { healthRoutes } from "./routes/health.js";
import { homeRoutes } from "./routes/home.js";
import { itemRoutes } from "./routes/items.js";
import { errorHandler } from "./middleware/error-handler.js";
import { correlationHook } from "./middleware/correlation.js";
import { requestLogger } from "./middleware/logging.js";
{%- if not (include_platform_auth | default(false)) %}
import { registerDevIdentity } from "./middleware/dev-identity.js";
{%- endif %}
// FORGE:MIDDLEWARE_IMPORTS

export async function buildApp() {
	// ``trustProxy: "uniquelocal"`` derives req.ip from X-Forwarded-For only
	// when the immediate peer is in a private/loopback range (the documented
	// Traefik front sits on the compose network), so rate-limit + logs see the
	// real client IP instead of collapsing every client onto the proxy address.
	// Public peers can't spoof XFF. Mirrors Python/Rust trusted-proxy keying.
	// (audit #14)
	const app = Fastify({ logger: true, bodyLimit: 1_048_576, trustProxy: "uniquelocal" });

	await app.register(cors);

	app.addHook("onRequest", correlationHook);
	app.addHook("onResponse", requestLogger);
	app.setErrorHandler(errorHandler);
{%- if not (include_platform_auth | default(false)) %}
	// Dev-mode identity fallback (auth.mode=none): bind a fixed local
	// identity so tenant-scoped repositories have a tenant/user to scope on.
	// Mirrors the Python dev passthrough. NEVER registered when the real
	// platform-auth plugin is wired (it owns identity + rejects anon requests).
	registerDevIdentity(app);
{%- endif %}
	// FORGE:MIDDLEWARE_REGISTRATION

	// Public routes — skip-listed by the platform-auth plugin, no
	// bearer required (liveness, readiness, service info).
	await app.register(homeRoutes, { prefix: "/api/v1" });
	await app.register(healthRoutes, { prefix: "/api/v1/health" });
	// FORGE:ROUTER_REGISTRATION_PUBLIC

	// Authenticated routes — the platformAuthPlugin registered above
	// (via bootstrapAuth) verifies the bearer token on every non-
	// skip-listed request via an onRequest hook, binding
	// ``req.identity`` for downstream handlers. Routes can opt into
	// finer-grained authorization via ``app.requireScope(...)``.
	await app.register(itemRoutes, { prefix: "/api/v1/{{ entity_plural }}" });
	// FORGE:ROUTER_REGISTRATION

	return app;
}
