# Multi-stage build with npm workspaces. The build context is this
# service directory, plus two `additional_contexts:` from compose:
#   * `project_root` — exposes the workspace root's package.json +
#     package-lock.json so `npm install --workspaces` knows the topology.
#   * `packages` — exposes the project-root packages/ tree so in-tree SDK source
#     (e.g. packages/platform-auth-node) is reachable. Without this the
#     generated `file:../packages/<name>` deps fail to resolve at build time
#     (BuildKit forbids paths above the main context).
#
# Build expects the workspace layout:
#   /workspace/                       (WORKDIR)
#     package.json + package-lock.json   (from project_root context)
#     packages/...                            (from packages context)
#     services/{{ project_slug }}/         (this service — main context)

# --- Builder Stage ---
FROM node:{{ node_version }}-slim AS builder

WORKDIR /workspace

# Workspace root manifests — declare workspaces + lockfile topology.
COPY --from=project_root package.json package-lock.json* ./

{%- if include_platform_auth | default(false) %}
# In-tree SDK source — only present when a project-root ``packages/`` tree ships
# (auth). Each SDK's `prepare` runs during the workspace install below to
# produce its dist/ artifacts. The compose ``packages`` build context is gated on
# the same condition (has_project_sdks); an unconditional COPY here would make
# BuildKit resolve ``packages`` as an image ref ("packages:latest") for a no-auth node
# project and fail.
COPY --from=packages . ./packages/
{%- endif %}

# This service's manifest, ahead of source, so the dep layer caches
# independently from src/ edits.
COPY package.json ./services/{{ project_slug }}/

# Workspace install: links every workspace member into the shared
# node_modules/ at the root and runs each member's `prepare` hook —
# the SDK's `prepare: tsc` produces packages/platform-auth-node/dist/
# before this service's downstream `tsc` ever runs. ``npm ci`` installs
# the exact tree the committed package-lock.json pins (reproducible,
# faster); fall back to ``npm install`` when the lockfile is absent
# (project generated on a host without Node, so forge couldn't resolve one).
RUN if [ -f package-lock.json ]; then \
        npm ci --workspaces --include-workspace-root; \
    else \
        npm install --workspaces --include-workspace-root; \
    fi

WORKDIR /workspace/services/{{ project_slug }}

COPY prisma ./prisma/
RUN npx prisma generate

COPY tsconfig.json ./
COPY src ./src/
RUN npm run build

# Ensure a per-service node_modules exists even when npm workspaces
# hoists every dep to /workspace/node_modules (which happens for
# minimal scenarios with no dep conflicts — e.g. node_svelte_min). The
# runtime stage's ``COPY --from=builder .../services/{slug}/node_modules``
# would otherwise fail BuildKit's checksum step with "not found".
RUN mkdir -p node_modules

# --- Runtime Stage ---
FROM node:{{ node_version }}-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Mirror the workspace layout in the runtime image so the workspace
# symlinks in node_modules/ resolve correctly. node_modules is copied
# verbatim from the builder rather than re-installed — workspace
# packages live inside the workspace tree, not in a public registry.
WORKDIR /workspace/services/{{ project_slug }}

COPY --from=builder /workspace/package.json /workspace/package-lock.json* /workspace/
COPY --from=builder /workspace/node_modules /workspace/node_modules/
{%- if include_platform_auth | default(false) %}
COPY --from=builder /workspace/packages /workspace/packages/
{%- endif %}
COPY --from=builder /workspace/services/{{ project_slug }}/node_modules ./node_modules/
COPY --from=builder /workspace/services/{{ project_slug }}/dist ./dist/
COPY --from=builder /workspace/services/{{ project_slug }}/prisma ./prisma/
COPY --from=builder /workspace/services/{{ project_slug }}/package.json ./

COPY config ./config/
COPY entrypoint.sh ./
RUN chmod +x entrypoint.sh

RUN groupadd --gid 10001 appuser \
    && useradd --uid 10001 --gid appuser --no-create-home --shell /usr/sbin/nologin appuser \
    && chown -R appuser:appuser /workspace
USER appuser

ENV NODE_ENV=production
EXPOSE {{ server_port }}

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -fsS "http://localhost:{{ server_port }}/api/v1/health/live" || exit 1

CMD ["/workspace/services/{{ project_slug }}/entrypoint.sh"]
