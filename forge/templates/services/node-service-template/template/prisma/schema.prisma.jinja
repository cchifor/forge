generator client {
  provider      = "prisma-client-js"
  // ``native`` covers the developer's host; the explicit Docker-runtime
  // targets cover the node:22-slim (Debian bookworm, OpenSSL 3.x) image on
  // both CPU architectures: ``debian-openssl-3.0.x`` (x86_64) and
  // ``linux-arm64-openssl-3.0.x`` (arm64 — Apple Silicon, arm64 Linux).
  // Without the matching arch+OpenSSL target the runtime container fails at
  // boot with ``PrismaClientInitializationError: ... could not locate the
  // Query Engine``. ``native`` alone is insufficient: on arm64 hosts Prisma
  // resolves ``native`` to ``linux-arm64-openssl-1.1.x``, which does not
  // load against the bookworm runtime's OpenSSL 3.x.
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Item {
  id          String     @id @default(uuid())
  customer_id String
  user_id     String
  name        String     @db.VarChar(255)
  description String?
  tags        String[]   @default([])
  status      ItemStatus @default(DRAFT)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@index([customer_id, name], map: "ix_items_customer_name")
  @@index([customer_id, status], map: "ix_items_customer_status")
  @@map("items")
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model BackgroundTask {
  id           String     @id @default(uuid())
  task_type    String     @db.VarChar(100)
  status       TaskStatus @default(PENDING)
  payload      Json?
  result       Json?
  error        String?
  attempts     Int        @default(0)
  max_retries  Int        @default(3)
  scheduled_at DateTime   @default(now())
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime   @default(now())

  @@index([status, scheduled_at], map: "ix_bg_tasks_status_scheduled")
  @@map("background_tasks")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   @db.VarChar(50)
  entity_type String?  @db.VarChar(100)
  entity_id   String?  @db.VarChar(255)
  username    String?  @db.VarChar(255)
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.VarChar(500)
  status_code Int?
  method      String?  @db.VarChar(10)
  path        String?  @db.VarChar(500)
  metadata    Json?    @map("meta_data")
  duration_ms Float?
  created_at  DateTime @default(now())

  @@map("audit_logs")
}
