[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_description }}"
requires-python = ">={{ python_version }}"
dependencies = [
    # Web Framework
    "fastapi>=0.115.0",
    "uvicorn>=0.34.0",
    "typer>=0.15.0",
    # Data Validation & Settings
    "pydantic>=2.11.0",
    "pydantic-settings>=2.12.0",
    # Database
    "sqlalchemy>=2.0.40",
    "asyncpg>=0.31.0",
    "aiosqlite>=0.22.0",
    "alembic>=1.18.0",
    # Dependency Injection
    "dishka>=1.8.0",
    # Authentication
    "python-keycloak>=5.3.0",
    "PyJWT>=2.10.0",
    # Service Discovery
    "py-eureka-client>=0.11.0",
    # Configuration
    "PyYAML>=6.0.0",
    "python-dotenv>=1.1.0",
    "deepmerge>=2.0",
    # Observability
    "opentelemetry-api>=1.20.0",
    "opentelemetry-sdk>=1.20.0",
    # HTTP Client (service-to-service)
    "httpx>=0.28.0",
    # Tenant Management Service — Redis (per-tenant routing cache + Valkey
    # Streams outbox relay) and idempotent provisioning.
    "redis>=7.4.0",
    "asgi-idempotency-header>=0.2.0",
    # Utilities
    "email-validator>=2.2.0",
    "python-multipart>=0.0.20",
    "cachetools>=5.5.0",
    # ---------------------------------------------------------------------
    # forge-core — vendored, framework-agnostic primitives (error
    # hierarchy + RFC-7807 wire model; persistence/domain/discovery land
    # in later blocks). Always shipped for Python services, inside this
    # backend at ``sdks/forge-core``; [tool.uv.sources] below points uv
    # at the backend-relative path-dep. The Dockerfile builds it to a
    # wheel and strips [tool.uv.sources] so the runtime image resolves
    # from /wheels.
    # ---------------------------------------------------------------------
    "forge-core",
{%- if include_platform_auth | default(false) %}
    # platform-auth — runtime SDK consumed by ``platform_auth_python_middleware``.
    # Source lives at ``packages/platform-auth/`` (shipped by the
    # ``platform_auth_sdk_python`` fragment); [tool.uv.sources] below
    # points uv at the path-dep.
    "platform-auth",
{%- endif %}
]

[tool.uv.sources]
# forge-core ships inside this backend (base template) at ``sdks/forge-core``,
# so its path-dep is backend-relative — unlike the platform-auth SDK which
# lives at the project-root ``packages/`` tree (``../../packages/...``).
forge-core = { path = "sdks/forge-core" }
{%- if include_platform_auth | default(false) %}
platform-auth = { path = "../../packages/platform-auth" }
{%- endif %}

[dependency-groups]
dev = [
    "pytest>=9.0.2",
    "pytest-asyncio>=1.3.0",
    "pytest-cov>=7.1.0",
    "httpx>=0.28.1",
    "ruff>=0.15.8",
    "ty>=0.0.1a1",
    "pre-commit>=3.5.0",
    "testcontainers[postgres]>=4.0.0",
    # In-memory Redis double for unit-testing the TMS routing publisher and
    # the outbox relay without a live Redis.
    "fakeredis>=2.26.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/app"]

[tool.pytest.ini_options]
pythonpath = ["src"]
testpaths = ["tests"]
asyncio_mode = "auto"
asyncio_default_fixture_loop_scope = "function"
addopts = "--cov --cov-report=term-missing --cov-report=html"
markers = [
    "slow: marks tests as slow",
    "integration: integration tests",
    "unit: unit tests",
    "docker: requires Docker daemon (testcontainers)",
]

[tool.ruff]
target-version = "py313"
line-length = 100
src = ["src", "tests"]
# Alembic migrations are auto-generated by ``alembic revision``; the
# SQL DDL parameter lists exceed the project line-length and aren't
# worth re-flowing on every revision.
extend-exclude = ["alembic/versions"]

[tool.ruff.lint]
select = ["E", "F", "I", "W"]

# ``ty`` configuration mirrors forge's own strictness — enforce a small,
# high-signal subset of rules that catch real bugs (call-site mismatch,
# missing/unknown arguments, unresolved imports, return-type drift) and
# leave the more exploratory rules (``unresolved-attribute`` on dynamic
# objects, blanket-``type: ignore`` audits, etc.) opt-in. Add a rule here
# only when the team has agreed it's worth the per-call-site noise.
[tool.ty.environment]
python-version = "3.13"

[tool.ty.src]
include = ["src"]
exclude = ["**/__pycache__", "**/.venv", "alembic/versions"]

[tool.ty.rules]
unresolved-import = "error"
invalid-argument-type = "error"
invalid-return-type = "error"
missing-argument = "error"
unknown-argument = "error"
# Silence the noisier rules — they fire on common, working Python idioms
# (dynamically-attached attributes on inner functions, ``__qualname__`` on
# coroutine wrappers, SQLAlchemy ``Result.rowcount``, dict-narrowing
# assignments). Re-enable individually once the template's structural
# issues are addressed; targeted ``# ty: ignore[<rule>]`` is preferred
# for a one-off site.
unresolved-attribute = "ignore"
invalid-assignment = "ignore"
invalid-raise = "ignore"
unused-type-ignore-comment = "ignore"

[tool.coverage.run]
source = ["src/app"]
omit = [
    "*/migrations/*",
    "*/alembic/*",
    "*/__pycache__/*",
    "*/conftest.py",
]

[tool.coverage.report]
# 60% accommodates fragment-injected code (RAG, conversation persistence,
# auth middleware, etc.) which adds ~500 LoC without proportionate
# tests in the base template. Bump back to 75% once you've added project-
# specific tests covering the active fragments.
fail_under = 60
show_missing = true
exclude_lines = [
    "pragma: no cover",
    "if __name__ == .__main__.",
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
    "@abstractmethod",
]

[tool.coverage.html]
directory = "htmlcov"
