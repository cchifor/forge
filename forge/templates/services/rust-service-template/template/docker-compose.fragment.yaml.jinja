# docker-compose fragment for the {{ project_slug }} Rust service. Mirrors
# the Python + Node templates so platform-level orchestration is uniform
# across language backends.

services:
  {{ project_slug }}-migrate:
    build:
      context: ./services/{{ project_slug }}
      dockerfile: Dockerfile
      # Workspace orchestration: project_root exposes the root
      # Cargo.toml + Cargo.lock; packages exposes in-tree SDK source.
      # Required so the multi-stage build can run
      # `cargo build --workspace` and resolve `path = "../packages/<name>"`
      # deps (BuildKit can't reach above the main build context without
      # these).
      additional_contexts:
        project_root: .
        packages: ./packages
    environment:
      RUST_LOG: info
      DATABASE_URL: "postgres://postgres:postgres@postgres:5432/{{ db_name }}"
    command: ["/app/migrate"]
    depends_on:
      postgres:
        condition: service_healthy
    networks: [app-network]

  {{ project_slug }}:
    build:
      context: ./services/{{ project_slug }}
      dockerfile: Dockerfile
      additional_contexts:
        project_root: .
        packages: ./packages
    ports:
      - "{{ server_port }}:{{ server_port }}"
    environment:
      # Dev stack overrides the image's ENV=production so the startup auth guard
      # (main.rs -> AppConfig::load) does not abort boot — the production profile
      # enables auth but this stack sets no GATEKEEPER_ISSUER/SERVICE_AUDIENCE.
      # Matches the Node/Python service fragments.
      ENV: development
      RUST_LOG: info
      PORT: "{{ server_port }}"
      DATABASE_URL: "postgres://postgres:postgres@postgres:5432/{{ db_name }}"
      OTEL_EXPORTER_OTLP_ENDPOINT: "http://alloy:4318"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ project_slug }}.rule=Host(`app.localhost`) && PathPrefix(`/api/{{ project_slug }}`)"
      - "traefik.http.routers.{{ project_slug }}.middlewares={{ project_slug }}-rewrite"
      - "traefik.http.middlewares.{{ project_slug }}-rewrite.replacepathregex.regex=^/api/{{ project_slug }}/(.*)"
      - "traefik.http.middlewares.{{ project_slug }}-rewrite.replacepathregex.replacement=/api/$$1"
      - "traefik.http.services.{{ project_slug }}.loadbalancer.server.port={{ server_port }}"
    depends_on:
      {{ project_slug }}-migrate:
        condition: service_completed_successfully
      keycloak:
        condition: service_healthy
    networks: [app-network]
