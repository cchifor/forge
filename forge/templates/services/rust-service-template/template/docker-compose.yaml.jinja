services:
  app:
    build: .
    ports:
      - "{{ server_port }}:{{ server_port }}"
    environment:
      # Local compose runs in development: the image pins ENV=production (so a
      # bare `docker run` is fail-closed), but the dev stack must override it or
      # the startup auth guard aborts boot (production profile enables auth but
      # this stack sets no GATEKEEPER_ISSUER/SERVICE_AUDIENCE). Matches Node/Python.
      ENV: development
      PORT: "{{ server_port }}"
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ db_name }}"
      RUST_LOG: info
    depends_on:
      postgres:
        condition: service_healthy

  postgres:
    image: postgres:16-alpine
    ports:
      - "5432:5432"
    environment:
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

  pgadmin:
    image: dpage/pgadmin4:latest
    ports:
      - "5050:80"
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@localhost.com
      PGADMIN_DEFAULT_PASSWORD: admin
    profiles:
      - tools

volumes:
  pgdata:
