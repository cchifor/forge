# Multi-stage build using Cargo workspaces. The build context is this
# service directory plus two `additional_contexts:` from compose:
#   * `project_root` — exposes the workspace-root Cargo.toml + Cargo.lock
#     so cargo resolves the workspace topology at build time.
#   * `packages` — exposes the project-root packages/ tree so `path = "../packages/<name>"`
#     deps resolve against /workspace/packages/<name>/ in the builder image
#     (BuildKit forbids paths above the main context without this).
#
# Build expects the workspace layout:
#   /workspace/                       (WORKDIR)
#     Cargo.toml + Cargo.lock            (from project_root context)
#     packages/...                            (from packages context)
#     services/{{ project_slug }}/         (this service — main context)

# --- Builder Stage ---
FROM rust:slim AS builder

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Workspace root: Cargo.toml + Cargo.lock declare the workspace topology.
COPY --from=project_root Cargo.toml Cargo.lock* ./

{%- if include_platform_auth | default(false) %}
# In-tree SDK source — path deps in Cargo.toml resolve against
# /workspace/packages/<name>/ at build time. Only copied when a project-root
# ``packages/`` tree actually ships (auth); the compose ``packages`` build context is
# gated on the same condition (has_project_sdks), so an unconditional COPY
# here would fail BuildKit for a no-auth rust project (missing context).
COPY --from=packages . ./packages/
{%- endif %}

# This service's manifest + migrations ahead of source so the cargo dep
# layer caches independently from src/ edits. sqlx::migrate! requires
# the migrations dir to exist for compile-time validation.
COPY Cargo.toml ./services/{{ project_slug }}/
COPY migrations ./services/{{ project_slug }}/migrations/

# Dep-priming dummy build at the workspace level. Cargo resolves every
# path = "../packages/<name>" against the workspace root, downloads + builds
# every transitive dep once, and caches the resulting target/ tree.
# ``--locked`` pins the exact versions the committed Cargo.lock resolved
# (reproducible builds); it's omitted when the lockfile is absent (project
# generated on a host without cargo, so forge couldn't resolve one).
RUN LOCKED=$([ -f Cargo.lock ] && echo --locked || true) \
    && mkdir -p services/{{ project_slug }}/src/bin \
    && echo "fn main() {}" > services/{{ project_slug }}/src/main.rs \
    && echo "fn main() {}" > services/{{ project_slug }}/src/bin/migrate.rs \
    && cargo build --release --workspace $LOCKED \
    && rm -rf services/{{ project_slug }}/src

# Copy real source and force rebuild only the binaries we ship — the
# workspace deps (incl. the SDK) stay cached. ``touch`` invalidates the
# bin targets so sqlx::migrate! re-embeds the migrations.
COPY src ./services/{{ project_slug }}/src/
RUN LOCKED=$([ -f Cargo.lock ] && echo --locked || true) \
    && touch services/{{ project_slug }}/src/main.rs services/{{ project_slug }}/src/bin/migrate.rs \
    && cargo build --release -p {{ project_name }} $LOCKED

# --- Runtime Stage ---
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libssl3 curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Binaries live at /workspace/target/release/ — cargo workspaces use a
# shared target/ directory at the workspace root, not per-package.
COPY --from=builder /workspace/target/release/{{ project_name }} /app/{{ project_name }}
COPY --from=builder /workspace/target/release/migrate /app/migrate

# Layered config profiles (RFC-008). The startup config load resolves
# config/<ENV>.yaml relative to the working dir, so the profiles must exist in
# the runtime image — parity with the Python and Node images, which both COPY
# config/ into their runtime stage. Without this the prod profile (and the
# fail-closed auth guard's view of it) would be silently absent.
COPY config /app/config

RUN groupadd --gid 10001 appuser \
    && useradd --uid 10001 --gid appuser --no-create-home --shell /usr/sbin/nologin appuser \
    && chown -R appuser:appuser /app
USER appuser

ENV PORT={{ server_port }}
# Default the runtime environment to production so the container loads the
# production config profile and the fail-closed auth guard applies (parity with
# the Python and Node service images, which set ENV/NODE_ENV=production). The
# config loader treats an UNSET env as the "development" profile, which ships
# auth disabled -- a containerized service must not silently fail open. Override
# at deploy time (e.g. -e ENV=staging) when appropriate.
ENV ENV=production
EXPOSE {{ server_port }}

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -fsS "http://localhost:{{ server_port }}/api/v1/health/live" || exit 1

CMD ["/app/{{ project_name }}"]
