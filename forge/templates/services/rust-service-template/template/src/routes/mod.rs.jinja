mod health;
mod home;
mod items;
// FORGE:ROUTES_MOD_REGISTRATION

use axum::Router;
use sqlx::PgPool;

// ``#[rustfmt::skip]`` keeps the ``FORGE:ROUTES_NESTED_REGISTRATION``
// marker pinned at the chain-method indent so fragments can inject
// ``.nest(...)`` calls before it without rustfmt reshuffling.
#[rustfmt::skip]
pub fn api_routes() -> Router<PgPool> {
    Router::new()
        .merge(home::routes())
        .nest("/health", health::routes())
        .nest("/{{ entity_plural }}", items::routes())
        // FORGE:ROUTES_NESTED_REGISTRATION
}
