# Multi-stage build: a wheel-building "builder" stage that resolves the
# service's deps + builds the vendored forge-core SDK (and, when auth is
# generated, the project-root platform-auth SDK), and a thin runtime stage
# that copies only the .venv and source.
#
# When the platform-auth SDK is referenced (auth.mode=generate), the project-
# root ``sdks/`` tree must be available at build time as the ``sdks`` build
# context:
#   docker build \
#     --build-context sdks=../../sdks \
#     -t {{ project_slug }} .
# docker-compose.yaml at the repo root already declares this via
# `additional_contexts: { sdks: ./sdks }` on each service.

# --- Builder Stage ---
FROM python:{{ python_version }}-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc libffi-dev libssl-dev curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.11.16 /uv /uvx /bin/

WORKDIR /project

# Vendored path-dep SDKs are resolved via [tool.uv.sources] in pyproject.toml.
# KEEP those sources (do NOT strip them) and place each SDK tree where its
# declared path points, so uv installs them from the LOCAL source. This is
# load-bearing for SECURITY: the vendored dist names (notably ``forge-core``)
# collide with unrelated packages on PyPI (a real ``forge-core`` exists, and
# even shares our version) — uv's source override is the ONLY thing that
# prevents a dependency-confusion install. Stripping the sources + relying on
# ``--find-links`` does NOT exclude PyPI and silently pulls the wrong package.
# ``--no-editable`` builds each SDK into the venv (copied wholesale to the
# runtime stage; the source ``sdks/`` tree itself is not carried forward).
#   - forge-core ships inside this backend at ``sdks/forge-core`` (main context).
#   - platform-auth ships at the project-root ``sdks/`` tree (the ``sdks``
#     build context) when auth.mode=generate.
COPY sdks/forge-core /project/sdks/forge-core
{%- if include_platform_auth | default(false) %}
COPY --from=sdks platform-auth /project/sdks/platform-auth
{%- endif %}
COPY pyproject.toml uv.lock* ./
{%- if include_platform_auth | default(false) %}
# platform-auth's [tool.uv.sources] path is project-root-relative
# (``../../sdks/platform-auth``) for the dev monorepo. Each service builds
# standalone in Docker (no project-root tree in this context), so retarget it
# to the backend-local copy COPYed above. This RETARGETS one path — it does
# NOT strip the source override, so the dependency-confusion guard stays.
RUN sed -i 's#\.\./\.\./sdks/platform-auth#sdks/platform-auth#' pyproject.toml
{%- endif %}
RUN uv sync --no-dev --no-editable

# Copy source
COPY src/ src/
COPY config/ config/
COPY alembic/ alembic/
COPY alembic.ini .
COPY entrypoint.sh ./
RUN chmod +x entrypoint.sh

# --- Runtime Stage ---
FROM python:{{ python_version }}-slim

WORKDIR /project

# Copy installed venv + source from the builder
COPY --from=builder /project/.venv /project/.venv
COPY --from=builder /project/src /project/src
COPY --from=builder /project/config /project/config
COPY --from=builder /project/alembic /project/alembic
COPY --from=builder /project/alembic.ini /project/alembic.ini
COPY --from=builder /project/entrypoint.sh /project/entrypoint.sh

ENV PATH="/project/.venv/bin:$PATH"
ENV PYTHONPATH=/project/src
ENV ENV=production

RUN adduser --disabled-password --no-create-home --uid 10001 appuser \
    && chown -R appuser:appuser /project
USER appuser

EXPOSE {{ server_port }}

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:{{ server_port }}/api/v1/health/live',timeout=3).status==200 else 1)"

CMD ["/project/entrypoint.sh"]
