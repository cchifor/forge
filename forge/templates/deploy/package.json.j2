{
  "name": "{{ project_slug }}-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for {{ project_name }} — orchestrates per-service builds and pre-builds in-tree SDKs (sdks/*).",
  "workspaces": [
    "apps/*",
    "services/*",
    "sdks/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
