# Compose profiles — optional service groups
#
# Full stack (all services):
#   COMPOSE_PROFILES=vectorstore docker compose up
#
# Slim stack (core services only, faster boot for dev/test):
#   docker compose up
#
# Services in the ``vectorstore`` profile (qdrant, chroma, weaviate) only
# start when the profile is active. Add ``COMPOSE_PROFILES=vectorstore``
# to your ``.env`` to enable them by default.

services:
{% for be in backends %}
{% if database_mode != "none" %}
  # ── Migrations for {{ be.name }} ──
  {{ be.name }}-migrate:
    build:
      context: ./services/{{ be.name }}
      dockerfile: Dockerfile
      # Multi-stage Dockerfiles reference the platform's weld-* SDK
      # source tree via ``COPY --from=sdks`` and the workspace root
      # (workspace package.json + lockfile) via ``COPY --from=project_root``.
      # ``additional_contexts`` binds those build-context names to the
      # on-disk ``./sdks/`` directory and the project root (sibling /
      # parent of the compose file). Unused contexts are harmless
      # overhead — BuildKit ignores them for Dockerfiles that don't
      # reference the name.
      additional_contexts:
        sdks: ./sdks
        project_root: .
    environment:
{% if be.language == "python" %}
      ENV: development
      APP__DB__URL: "postgresql+asyncpg://postgres:postgres@postgres:5432/{{ be.db_name }}"
    command: ["python", "-m", "app", "db", "upgrade"]
{% elif be.language == "node" %}
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
    command: ["npx", "prisma", "migrate", "deploy"]
{% elif be.language == "rust" %}
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
    command: ["/app/migrate"]
{% endif %}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - app-network
{% endif %}

  # ── {{ be.name }} ──
  {{ be.name }}:
    build:
      context: ./services/{{ be.name }}
      dockerfile: Dockerfile
      # See the {{ be.name }}-migrate build above — same rationale.
      additional_contexts:
        sdks: ./sdks
        project_root: .
    # Direct host:container port so the matrix-nightly lane-C smoke
    # contract — and any local ``curl http://localhost:{{ be.port }}`` —
    # can reach the backend without going through Traefik. The Traefik
    # entry above remains for the production-shape ``app.localhost``
    # route; this is the dev/test stack so exposing both is fine.
    ports:
      - "{{ be.port }}:{{ be.port }}"
    environment:
{% if be.language == "python" %}
      ENV: development
{% if database_mode != "none" %}
      APP__DB__URL: "postgresql+asyncpg://postgres:postgres@postgres:5432/{{ be.db_name }}"
{% endif %}
{% elif be.language == "node" %}
      NODE_ENV: development
      # The Node config loader reads ``APP__SERVER__PORT`` (RFC-008
      # prefix); plain ``PORT`` is a Node-ecosystem convention but isn't
      # wired into our schema, so the listener would otherwise bind to
      # the schema default (5000) and the host:container port mapping
      # above would land on a closed port inside the container.
      APP__SERVER__PORT: "{{ be.port }}"
{% if database_mode != "none" %}
      # ``APP__DB__URL`` is consumed by the Zod schema; ``DATABASE_URL``
      # is what Prisma reads. Both must point at the in-network postgres
      # host or boot will fail (Zod) / migrations will misroute (Prisma).
      APP__DB__URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
{% endif %}
{% elif be.language == "rust" %}
      PORT: "{{ be.port }}"
{% if database_mode != "none" %}
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
{% endif %}
      RUST_LOG: info
{% endif %}
{% if include_keycloak %}
      APP__SECURITY__AUTH__ENABLED: "true"
      APP__SECURITY__AUTH__SERVER_URL: "http://keycloak:8080"
      APP__SECURITY__AUTH__REALM: "{{ keycloak_realm }}"
      APP__SECURITY__AUTH__CLIENT_ID: "{{ keycloak_client_id }}"
      GATEKEEPER_ISSUER: "http://gatekeeper:5000"
      SERVICE_AUDIENCE: "forge-services"
{% else %}
      APP__SECURITY__AUTH__ENABLED: "false"
{% endif %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ be.name }}.rule=Host(`app.localhost`) && PathPrefix(`/api/{{ be.name }}`)"
      - "traefik.http.routers.{{ be.name }}.entrypoints=web"
      - "traefik.http.middlewares.{{ be.name }}-rewrite.replacepathregex.regex=^/api/{{ be.name }}/(.*)"
      - "traefik.http.middlewares.{{ be.name }}-rewrite.replacepathregex.replacement=/api/$$1"
{% if include_keycloak %}
      - "traefik.http.routers.{{ be.name }}.middlewares={{ be.name }}-rewrite,auth"
{% else %}
      - "traefik.http.routers.{{ be.name }}.middlewares={{ be.name }}-rewrite"
{% endif %}
      - "traefik.http.services.{{ be.name }}.loadbalancer.server.port={{ be.port }}"
{% if database_mode != "none" or include_keycloak %}
    depends_on:
{% if database_mode != "none" %}
      {{ be.name }}-migrate:
        condition: service_completed_successfully
{% endif %}
{% if include_keycloak %}
      keycloak:
        condition: service_healthy
{% endif %}
{% endif %}
    networks:
      - app-network
{% endfor %}

{% if render_postgres %}
  # ── Database ──
  # ``pgvector/pgvector:pg16`` is a superset of stock ``postgres:16``
  # with the ``pgvector`` extension preinstalled. The ``rag_pipeline``
  # fragment's ``CREATE EXTENSION IF NOT EXISTS vector`` migration
  # would otherwise fail at ``alembic upgrade head`` for any scenario
  # that enables RAG (chroma backend included — the migration runs
  # regardless of the configured vector store; see RFC notes).
  # Non-RAG scenarios pay a negligible ~30 MB image-size delta.
  postgres:
    image: pgvector/pgvector:pg16
    ports:
      - "15432:5432"
    environment:
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    volumes:
      - pgdata:/var/lib/postgresql/data
{% if backends | length > 1 or include_keycloak %}
      - ./init-db.sh:/docker-entrypoint-initdb.d/init-db.sh
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - app-network
{% endif %}

{% if has_frontend %}
  # ── Frontend (nginx — static files + SPA fallback only) ──
  frontend:
    build:
      context: ./apps/{{ frontend_slug }}
      dockerfile: Dockerfile
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.frontend.rule=Host(`app.localhost`)"
      - "traefik.http.routers.frontend.entrypoints=web"
      - "traefik.http.services.frontend.loadbalancer.server.port=80"
{% if backends %}
    depends_on:
{% for be in backends %}
      - {{ be.name }}
{% endfor %}
{% endif %}
    networks:
      - app-network
{% endif %}

  # ── API Gateway ──
  traefik:
    image: traefik:v2.11
    ports:
      - "80:80"
      - "{{ traefik_dashboard_port }}:8080"
    environment:
      TRAEFIK_API_INSECURE: "true"
      TRAEFIK_PROVIDERS_DOCKER: "true"
      TRAEFIK_PROVIDERS_DOCKER_EXPOSEDBYDEFAULT: "false"
      TRAEFIK_ENTRYPOINTS_WEB_ADDRESS: ":80"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - app-network

{% if include_keycloak %}
  # Gatekeeper (OIDC ForwardAuth + token authority) is now contributed
  # by the ``platform_auth_gatekeeper`` + ``platform_auth_gatekeeper_keygen``
  # fragments via declarative compose.yaml entries (registered through
  # ``forge.services.fragment_compose``). The fragments build the
  # service block from the same ``./infra/gatekeeper/`` source tree that
  # used to be hand-rolled here.

  # ── Identity Provider ──
  keycloak:
    build:
      context: ./infra/keycloak
      dockerfile: Dockerfile
    command: start-dev --import-realm
    ports:
      - "{{ keycloak_port }}:8080"
    environment:
      KC_DB: postgres
      KC_DB_URL_HOST: postgres
      KC_DB_URL_DATABASE: keycloak
      KC_DB_USERNAME: postgres
      KC_DB_PASSWORD: postgres
      KC_HEALTH_ENABLED: "true"
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: admin
    volumes:
      - ./infra/keycloak-realm.json:/opt/keycloak/data/import/realm.json:ro
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "cat < /dev/null > /dev/tcp/localhost/9000"]
      interval: 10s
      timeout: 5s
      retries: 15
      start_period: 30s
    networks:
      - app-network

  # ── Session Cache ──
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - app-network
{% endif %}

{% if render_postgres %}
  # ── Tools (optional) ──
  pgadmin:
    image: dpage/pgadmin4:latest
    ports:
      - "5050:80"
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@localhost.com
      PGADMIN_DEFAULT_PASSWORD: admin
    profiles:
      - tools
    networks:
      - app-network
{% endif %}

{% if has_frontend %}
  # ── E2E Tests (on-demand: docker compose --profile test run e2e) ──
  # Runs on the host network so app.localhost resolves to 127.0.0.1
  # where Traefik is listening — identical to real user experience.
  e2e:
    build:
      context: ./tests/e2e
      dockerfile: Dockerfile
    network_mode: host
    environment:
      BASE_URL: "http://app.localhost"
      CI: "true"
{% if include_keycloak %}
      TEST_USER: "dev@localhost"
      TEST_PASSWORD: "devpass"
{% endif %}
    depends_on:
      - frontend
{% for be in backends %}
      - {{ be.name }}
{% endfor %}
{% if include_keycloak %}
      - gatekeeper
{% endif %}
    profiles:
      - test
{% endif %}

{% for svc in extra_services %}
  # ── Plugin service: {{ svc.name }} ──
  {{ svc.name }}:
{% for key, value in svc.block.items() %}
{% if value is mapping %}
    {{ key }}:
{% for k, v in value.items() %}
      {{ k }}: {{ v | tojson }}
{% endfor %}
{% elif value is sequence and value is not string %}
    {{ key }}:
{% for item in value %}
      - {{ item }}
{% endfor %}
{% else %}
    {{ key }}: {{ value | tojson }}
{% endif %}
{% endfor %}
{% endfor %}

{% if render_postgres or extra_volumes %}
volumes:
{% if render_postgres %}
  pgdata:
{% if include_keycloak %}
  redis_data:
{% endif %}
{% endif %}
{% for vol in extra_volumes %}
  {{ vol }}:
{% endfor %}
{% endif %}

networks:
  app-network:
    driver: bridge
