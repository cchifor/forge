# -- Build stage --
FROM node:22-slim AS builder
WORKDIR /app

{% if package_manager == "pnpm" %}
RUN corepack enable && corepack prepare pnpm@latest --activate
{% elif package_manager == "yarn" %}
RUN corepack enable
{% elif package_manager == "bun" %}
RUN npm install -g bun
{% endif %}

{% if package_manager == "pnpm" %}
COPY package.json pnpm-lock.yaml* ./
# Frozen install when the committed lockfile is present (reproducible);
# fall back to a resolving install when it's absent (project generated on
# a host without pnpm, so forge couldn't resolve one).
RUN if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile; else pnpm install; fi
{% elif package_manager == "yarn" %}
COPY package.json yarn.lock* ./
RUN if [ -f yarn.lock ]; then yarn install --frozen-lockfile; else yarn install; fi
{% elif package_manager == "bun" %}
COPY package.json bun.lockb* ./
RUN if [ -f bun.lockb ]; then bun install --frozen-lockfile; else bun install; fi
{% else %}
COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi
{% endif %}

COPY . .
RUN {{ package_manager }} run build

# -- Runtime stage --
FROM nginx:alpine

COPY --from=builder /app/{{ build_dir }} /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
