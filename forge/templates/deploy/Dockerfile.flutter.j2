# -- Build stage --
FROM ghcr.io/cirruslabs/flutter:stable AS builder
WORKDIR /app

COPY . .
# Scaffold the web platform for the generated project. The template ships lib/
# + pubspec.yaml but not web/, so `flutter build web` would otherwise fail with
# "To configure this project for the web, run flutter create . --platforms web".
# `flutter create .` is additive — it adds web/ (index.html, manifest, bootstrap)
# without touching lib/, reusing the existing pubspec name.
RUN flutter create . --platforms web
RUN flutter pub get
# Run code generation. The project uses freezed / riverpod_generator /
# json_serializable / retrofit_generator, whose *.g.dart and *.freezed.dart
# outputs are not committed (and host-side `forge` only runs build_runner when
# the Flutter SDK is present). Without this step `flutter build web` fails with
# "Error when reading '...g.dart': No such file or directory" for every codegen
# source.
RUN dart run build_runner build --delete-conflicting-outputs
RUN flutter build web --release

# -- Runtime stage --
FROM nginx:alpine

COPY --from=builder /app/build/web /usr/share/nginx/html
# nginx.conf is NOT baked into the image — it is supplied at runtime: a
# bind-mount in docker-compose, a ConfigMap in the Helm chart. This keeps the
# routing config a deployment concern (overridable per environment) rather than
# a build-time constant.

EXPOSE 80
