import type { Page } from '@playwright/test';

export class Navigation {
  constructor(private readonly page: Page) {}

  async goTo(feature: string): Promise<void> {
    console.log(`[nav] → /${feature}`);
    const resp = await this.page.goto(`/${feature}`);
    console.log(`[nav] ← ${resp?.status()} ${this.page.url()}`);
  }

  async goToCreate(feature: string): Promise<void> {
    console.log(`[nav] → /${feature}/new`);
    const resp = await this.page.goto(`/${feature}/new`);
    console.log(`[nav] ← ${resp?.status()} ${this.page.url()}`);
  }

  async goToDetail(feature: string, id: string): Promise<void> {
    console.log(`[nav] → /${feature}/${id}`);
    const resp = await this.page.goto(`/${feature}/${id}`);
    console.log(`[nav] ← ${resp?.status()} ${this.page.url()}`);
  }

  async goToDashboard(): Promise<void> {
    console.log('[nav] → /');
    const resp = await this.page.goto('/');
    console.log(`[nav] ← ${resp?.status()} ${this.page.url()}`);
  }

  async goToSettings(): Promise<void> {
    console.log('[nav] → /settings');
    await this.page.goto('/settings');
  }
}
