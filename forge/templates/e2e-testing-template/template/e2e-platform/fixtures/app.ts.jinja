import { test as base } from '@playwright/test';
import { Navigation } from '../actions/Navigation';
import { ApiHelper } from '../actions/ApiHelper';
import { Assertions } from '../actions/Assertions';
{% if include_auth %}
import { AuthManager } from '../auth/AuthManager';
{% endif %}

export type AppFixtures = {
  app: {
    nav: Navigation;
    api: ApiHelper;
    assertions: Assertions;
    page: import('@playwright/test').Page;
{% if include_auth %}
    auth: AuthManager;
{% endif %}
  };
};

export const test = base.extend<AppFixtures>({
  app: async ({ page, request{% if include_auth %}, context{% endif %} }, use) => {
{% if include_auth %}
    // Pass a cookie getter so API calls include the session cookie
    const getCookies = async () => {
      const cookies = await context.cookies();
      return cookies.map(c => `${c.name}=${c.value}`).join('; ');
    };
{% endif %}
    await use({
      nav: new Navigation(page),
      api: new ApiHelper(request{% if include_auth %}, getCookies{% endif %}),
      assertions: new Assertions(page),
      page,
{% if include_auth %}
      auth: new AuthManager(page, context),
{% endif %}
    });
  },
});

export { expect } from '@playwright/test';
