<script setup lang="ts">
import { computed } from 'vue'
import { useRoute, useRouter } from 'vue-router'
import {
  Home,
  User,
  Settings,
  LogOut,
  SlidersHorizontal,
  Sparkles,
  Menu,
} from 'lucide-vue-next'
import { Avatar, AvatarFallback } from '@/shared/ui/avatar'
import { useUiStore } from '@/shared/stores/ui.store'
import {
  DropdownMenu,
  DropdownMenuTrigger,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
} from '@/shared/ui/dropdown-menu'
{% if include_chat %}import { AiChatButton } from '@/features/ai_chat'
{% endif %}import { useAuth } from '@/shared/composables/useAuth'

defineProps<{ compact?: boolean }>()

const emit = defineEmits<{ 'toggle-mobile-menu': [] }>()

const route = useRoute()
const router = useRouter()
const uiStore = useUiStore()
const { user, logout } = useAuth()

const primaryNav = [
  { title: 'Home', url: '/', icon: Home },
  // --- feature nav items ---
  // --- end feature nav items ---
]

function isActive(url: string) {
  if (url === '/') return route.path === '/'
  return route.path.startsWith(url)
}

const userInitials = computed(() => {
  if (!user.value) return '?'
  return (
    (user.value.firstName?.[0] ?? '') + (user.value.lastName?.[0] ?? '')
  ).toUpperCase() || user.value.username[0]?.toUpperCase() || '?'
})
</script>

<template>
  <header
    class="sticky top-0 z-30 flex h-14 shrink-0 items-center gap-2 border-b bg-card px-4"
  >
    <!-- Hamburger (collapsed tiers only) -->
    <button
      v-if="compact"
      class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl hover:bg-accent interactive-press"
      type="button"
      title="Open menu"
      aria-label="Open navigation menu"
      aria-controls="topnav-mobile-drawer"
      :aria-expanded="uiStore.mobileMenuOpen"
      @click="emit('toggle-mobile-menu')"
    >
      <Menu class="h-5 w-5 text-muted-foreground" />
    </button>

    <!-- Logo -->
    <RouterLink
      to="/"
      aria-label="{{ app_title }} home"
      class="flex shrink-0 items-center gap-2 rounded-xl px-1 interactive-press"
    >
      <div class="flex h-8 w-8 items-center justify-center rounded-lg ai-gradient">
        <Sparkles class="h-4 w-4 text-white" />
      </div>
      <span
        v-if="!compact"
        class="truncate text-sm font-semibold text-foreground"
      >
        {{ app_title }}
      </span>
    </RouterLink>

    <!-- Inline primary nav (expanded tier only) -->
    <nav v-if="!compact" class="ml-4 flex items-center gap-1">
      <RouterLink
        v-for="item in primaryNav"
        :key="item.url"
        :to="item.url"
        :aria-current="isActive(item.url) ? 'page' : undefined"
        class="flex h-9 items-center gap-2 rounded-xl px-3 text-sm interactive-press"
        :class="isActive(item.url)
          ? 'bg-primary/10 font-semibold text-primary'
          : 'text-muted-foreground hover:bg-accent hover:text-foreground'"
      >
        <component :is="item.icon" class="h-4 w-4" />
        <span>{% raw %}{{ item.title }}{% endraw %}</span>
      </RouterLink>
    </nav>

    <!-- Right cluster -->
    <div class="ml-auto flex items-center gap-2">
{% if include_chat %}      <AiChatButton />
{% endif %}
      <DropdownMenu>
        <DropdownMenuTrigger as-child>
          <button
            type="button"
            aria-label="Open account menu"
            class="flex items-center gap-2 rounded-xl p-1 hover:bg-accent interactive-press"
          >
            <Avatar class="h-8 w-8">
              <AvatarFallback class="text-xs">{% raw %}{{ userInitials }}{% endraw %}</AvatarFallback>
            </Avatar>
            <span
              v-if="!compact"
              class="hidden max-w-[10rem] truncate text-sm font-medium text-foreground md:inline"
            >
              {% raw %}{{ user?.firstName }} {{ user?.lastName }}{% endraw %}
            </span>
          </button>
        </DropdownMenuTrigger>
        <DropdownMenuContent side="bottom" align="end" class="w-56">
          <DropdownMenuLabel>My Account</DropdownMenuLabel>
          <DropdownMenuSeparator />
          <DropdownMenuItem @click="router.push('/profile')">
            <User class="mr-2 h-4 w-4" />
            Account Settings
          </DropdownMenuItem>
          <DropdownMenuItem @click="router.push('/settings')">
            <SlidersHorizontal class="mr-2 h-4 w-4" />
            Preferences
          </DropdownMenuItem>
          <DropdownMenuSeparator />
          <DropdownMenuItem @click="logout">
            <LogOut class="mr-2 h-4 w-4" />
            Log Out
          </DropdownMenuItem>
        </DropdownMenuContent>
      </DropdownMenu>
    </div>
  </header>
</template>
