{% raw %}<script lang="ts">
	import { goto } from '$app/navigation';
	import { getAuth } from '$lib/core';
	import { getUiStore } from '$lib/features/shell';
	import TopNavBar from '$lib/features/shell/ui/TopNavBar.svelte';
	import TopNavDrawer from '$lib/features/shell/ui/TopNavDrawer.svelte';
	import AppFooter from '$lib/features/shell/ui/AppFooter.svelte';{% endraw %}{% if include_chat %}
	{% raw %}import { AiChat } from '$lib/features/chat';
	import ChatDrawer from '$lib/features/shell/ui/ChatDrawer.svelte';
	import ChatBottomSheet from '$lib/features/shell/ui/ChatBottomSheet.svelte';
	import VerticalSplitHandle from '$lib/features/shell/ui/VerticalSplitHandle.svelte';{% endraw %}{% endif %}{% raw %}

	let { children } = $props();
	const auth = getAuth();
	const ui = getUiStore();

	$effect(() => {
		if (!auth.isLoading && !auth.isAuthenticated) {
			goto('/login');
		}
	});{% endraw %}{% if include_chat %}

	{% raw %}function handleKeydown(e: KeyboardEvent) {
		if ((e.metaKey || e.ctrlKey) && e.key === 'j') {
			e.preventDefault();
			ui.toggleChat();
		}
	}

	// Splitter drag logic for the expanded inline chat. No persistent side nav
	// in this shell, so chat width is measured from the right viewport edge.
	function handleDragMove(clientX: number) {
		const chatPx = window.innerWidth - clientX;
		ui.setChatWidth(chatPx);
	}{% endraw %}{% endif %}{% raw %}
</script>{% endraw %}{% if include_chat %}

{% raw %}<svelte:window onkeydown={handleKeydown} />{% endraw %}{% endif %}{% raw %}

{#if auth.isAuthenticated}
	{#if ui.isMobile}
		<!-- COMPACT: compact TopNavBar + TopNavDrawer + full-width content + AppFooter -->
		<div class="flex h-svh flex-col overflow-hidden">
			<TopNavBar compact />
			<main class="flex-1 overflow-y-auto">
				<div class="mx-auto w-full max-w-screen-xl p-4">{@render children()}</div>
			</main>
			<AppFooter />
		</div>
		<TopNavDrawer />{% endraw %}{% if include_chat %}
		{% raw %}{#if ui.chatOpen}
			<ChatBottomSheet bind:open={() => ui.chatOpen, (v) => { if (!v) ui.closeChat(); }}>
				<AiChat mode="sheet" />
			</ChatBottomSheet>
		{/if}{% endraw %}{% endif %}{% raw %}
	{:else if ui.isMedium}
		<!-- MEDIUM: compact TopNavBar + TopNavDrawer + content + AppFooter -->
		<div class="flex h-svh flex-col overflow-hidden">
			<TopNavBar compact />
			<main class="flex-1 overflow-y-auto">
				<div class="mx-auto w-full max-w-screen-xl p-4">{@render children()}</div>
			</main>
			<AppFooter />
		</div>
		<TopNavDrawer />{% endraw %}{% if include_chat %}
		{% raw %}{#if ui.chatOpen}
			<ChatDrawer bind:open={() => ui.chatOpen, (v) => { if (!v) ui.closeChat(); }}>
				<AiChat mode="drawer" />
			</ChatDrawer>
		{/if}{% endraw %}{% endif %}{% raw %}
	{:else}
		<!-- EXPANDED: TopNavBar + centered content + AppFooter + inline chat -->
		<div class="flex h-svh overflow-hidden">
			<div class="flex flex-1 flex-col overflow-hidden min-w-0">
				<TopNavBar />
				<main class="flex-1 overflow-y-auto">
					<div class="mx-auto w-full max-w-screen-xl p-4">{@render children()}</div>
				</main>
				<AppFooter />
			</div>{% endraw %}{% if include_chat %}
			{% raw %}{#if ui.chatOpen}
				<VerticalSplitHandle ondragmove={handleDragMove} />
				<div
					style="width: {ui.chatWidth}px"
					class="flex-shrink-0 border-l overflow-hidden"
				>
					<AiChat mode="inline" />
				</div>
			{/if}{% endraw %}{% endif %}{% raw %}
		</div>
	{/if}
{/if}{% endraw %}
