{
  "name": "{{ project_slug }}",
  "private": true,
  "version": "{{ version }}",
  "type": "module",
  "scripts": {
{%- if include_openapi %}
    "codegen": "openapi-ts",
    "predev": "{{ package_manager }} run codegen || true",
{%- endif %}
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
{%- if include_chat %}
    "@ag-ui/client": "^0.0.51",
    "@ag-ui/core": "^0.0.51",
    "@modelcontextprotocol/ext-apps": "^0.1.0",
    "fast-json-patch": "^3.1.1",
    "dompurify": "^3.3.3",
    "marked": "^18.0.0",
{%- endif %}
    "@tanstack/vue-query": "^5.75.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^13.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ky": "^1.8.1",
    "lucide-vue-next": "^0.475.0",
    "pinia": "^3.0.2",
    "radix-vue": "^1.9.17",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "vue-sonner": "^1.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
{%- if include_openapi %}
    "@hey-api/openapi-ts": "^0.66.0",
{%- endif %}
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^26.1.0",
    "msw": "^2.8.4",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "unplugin-auto-import": "^19.2.0",
    "vite": "^6.3.3",
    "vitest": "^3.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.8"
  }
}
