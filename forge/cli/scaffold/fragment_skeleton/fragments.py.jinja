from __future__ import annotations

from pathlib import Path

from forge.api import ForgeAPI
from forge.config import BackendLanguage
from forge.fragments import Fragment, FragmentImplSpec

_FRAGMENT_ROOT = Path(__file__).resolve().parent


def register_{{ name }}(api: ForgeAPI) -> None:
    """Register the ``{{ name }}`` fragment with forge."""
    api.add_fragment(
        Fragment(
            name="{{ name }}",
            implementations={
{%- for backend in backends %}
                BackendLanguage.{{ backend_const(backend) }}: FragmentImplSpec(
                    fragment_dir=str(_FRAGMENT_ROOT / "{{ backend }}"),
                    # TODO: declare per-backend dependencies for {{ backend }}.
                    dependencies=(),
                    # TODO: declare per-backend env vars for {{ backend }}.
                    env_vars=(),
                ),
{%- endfor %}
            },
            # TODO: declare hard dependencies (other fragments that must
            # also be in the plan if this one is). Soft ordering goes in
            # ``before=`` / ``after=`` instead.
            depends_on=(),
            # TODO: declare fragments that cannot coexist with this one.
            conflicts_with=(),
            # TODO: declare runtime capabilities (e.g. ``("redis",)``).
            capabilities=(),
        )
    )
