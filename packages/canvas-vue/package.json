{
  "name": "@forge/canvas-vue",
  "version": "1.0.0-alpha.5",
  "description": "Canvas registry + AG-UI streaming for forge-generated Vue applications. Re-exports the framework-agnostic protocol surface from @forge/canvas-core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.56",
    "@ag-ui/core": "^0.0.57",
    "@forge/canvas-core": "^1.0.0-alpha.1",
    "marked": "^18.0.4",
    "dompurify": "^3.2.0",
    "highlight.js": "^11.10.0"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "typescript": "^6.0.3",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/forge-project/forge.git",
    "directory": "packages/canvas-vue"
  }
}
