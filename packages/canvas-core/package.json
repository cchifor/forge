{
  "name": "@forge/canvas-core",
  "version": "1.0.0-alpha.2",
  "description": "Framework-agnostic AG-UI reducer, SSE client, and MCP iframe bridge for forge canvas packages.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.55",
    "fast-json-patch": "^3.1.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "jsdom": "^29.1.1",
    "@types/node": "^25.9.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cchifor/forge.git",
    "directory": "packages/canvas-core"
  }
}
