#!/usr/bin/env bash
# No `errexit` (`set -e`): this is a bootstrap installer whose steps return
# non-zero by design — the uv installer exits non-zero in a non-interactive
# shell, and the cosmetic `… | head` version pipelines SIGPIPE under pipefail.
# macOS ships bash 3.2, whose errexit/pipefail/`|| true` handling aborts the
# script even on guarded commands (observed: it died right after a SUCCESSFUL
# uv install on macOS CI). We keep `nounset` + `pipefail` and verify the two
# things that actually matter — uv and forge — explicitly instead.
set -uo pipefail

REPO="https://github.com/cchifor/forge.git"
TOOL="git+${REPO}"

MUTED='\033[0;2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
WARN='\033[38;5;214m'
NC='\033[0m'

# -- OS detection -------------------------------------------------------------

raw_os=$(uname -s)
case "$raw_os" in
  Darwin*)               os="macos" ;;
  Linux*)                os="linux" ;;
  MINGW*|MSYS*|CYGWIN*)  os="windows" ;;
  *)                     os="unknown" ;;
esac

# Detect WSL (reports Linux but is actually Windows)
if [[ "$os" == "linux" ]] && grep -qi microsoft /proc/version 2>/dev/null; then
  os="windows"
fi

# -- Helpers ------------------------------------------------------------------

installed() {
  command -v "$1" &>/dev/null
}

ps_exec() {
  powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$1"
}

get_version() {
  "$@" 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+[.0-9]*' | head -1
}

# -- Banner -------------------------------------------------------------------

echo -e ""
echo -e "  +===================================+"
echo -e "  |        ${NC}forge installer${MUTED}             |${NC}"
echo -e "  +===================================+"
echo -e ""
echo -e "  ${MUTED}Detected OS:${NC} $os"
echo -e ""

# -- uv (REQUIRED) -----------------------------------------------------------

if installed uv; then
  echo -e "  ${GREEN}[ok]${NC} uv $(get_version uv --version)"
else
  echo -e "  ${MUTED}Installing uv...${NC}"
  if [[ "$os" == "windows" ]]; then
    ps_exec "irm https://astral.sh/uv/install.ps1 | iex" 2>&1 | sed 's/^/    /'
  else
    curl -LsSf https://astral.sh/uv/install.sh | sh 2>&1 | sed 's/^/    /'
  fi
  # Refresh PATH: uv installs to ~/.local/bin. Source its env file if present,
  # and add the dir unconditionally so the verify below finds uv regardless.
  if [[ "$os" == "windows" ]]; then
    eval "$(powershell.exe -NoProfile -Command '
      $p = [System.Environment]::GetEnvironmentVariable("Path","User") + ";" +
           [System.Environment]::GetEnvironmentVariable("Path","Machine")
      $p -split ";" | ForEach-Object { if ($_) { "export PATH=\"" + ($_ -replace "\\\\","/") + ":\$PATH\"" } }
    ')" 2>/dev/null
  else
    source "$HOME/.local/bin/env" 2>/dev/null || true
    export PATH="$HOME/.local/bin:$PATH"
  fi
  if installed uv; then
    echo -e "  ${GREEN}[ok]${NC} uv $(get_version uv --version)"
  else
    echo -e "  ${RED}[!!] uv installation failed. Aborting.${NC}"
    exit 1
  fi
fi

# -- git (recommended) -------------------------------------------------------

if installed git; then
  echo -e "  ${GREEN}[ok]${NC} git $(get_version git --version)"
else
  echo -e "  ${WARN}[--]${NC} git not found ${MUTED}(needed for project generation)${NC}"
  case "$os" in
    macos)
      echo -e "       ${MUTED}Run:${NC} xcode-select --install" ;;
    linux)
      echo -e "       ${MUTED}Run:${NC} sudo apt install git ${MUTED}(or your distro equivalent)${NC}" ;;
    windows)
      echo -e "       ${MUTED}Run:${NC} winget install Git.Git" ;;
  esac
fi

# -- docker (recommended) ----------------------------------------------------

if installed docker; then
  echo -e "  ${GREEN}[ok]${NC} docker $(get_version docker --version)"
else
  echo -e "  ${WARN}[--]${NC} docker not found ${MUTED}(needed to run the generated stack)${NC}"
  case "$os" in
    macos|windows)
      echo -e "       ${MUTED}Download:${NC} https://docker.com/products/docker-desktop" ;;
    linux)
      echo -e "       ${MUTED}Run:${NC} curl -fsSL https://get.docker.com | sh" ;;
  esac
fi

echo -e ""

# -- Install forge --------------------------------------------------------

echo -e "  ${MUTED}Installing forge...${NC}"
echo -e ""

if [[ "$os" == "windows" ]]; then
  ps_exec "uv tool install --force $TOOL" 2>&1 | sed 's/^/    /'
else
  uv tool install --force "$TOOL" 2>&1 | sed 's/^/    /'
fi
# Capture uv's exit code (not sed's) — without errexit a failed install would
# otherwise pass silently, and a pre-existing `forge` on PATH (e.g. Foundry's)
# could make the verify below report false success.
install_rc=${PIPESTATUS[0]}

# uv installs the `forge` shim into its tool bin dir, which is configurable
# (UV_TOOL_BIN_DIR / XDG_BIN_HOME) — ask uv rather than assuming ~/.local/bin.
# Prepend it so the uv-installed forge wins over any other `forge` on PATH.
uv_bin="$(uv tool dir --bin 2>/dev/null || echo "$HOME/.local/bin")"
export PATH="$uv_bin:$PATH"

forge_path="$(command -v forge 2>/dev/null || true)"
if [ "$install_rc" -ne 0 ] || [ -z "$forge_path" ]; then
  echo -e ""
  echo -e "  ${RED}[!!] forge installation failed.${NC} See the output above."
  echo -e "  ${MUTED}You can retry with: uv tool install --force ${TOOL}${NC}"
  exit 1
fi
# Warn (don't fail) if a DIFFERENT `forge` shadows ours — e.g. Foundry also
# ships a `forge`. We prepended uv_bin, so this only triggers on odd setups.
case "$os:$forge_path" in
  windows:*) : ;;  # path semantics differ under git-bash; skip the check
  *:"$uv_bin"/*) : ;;  # the uv-installed forge — good
  *)
    echo -e "  ${WARN}[--]${NC} another 'forge' is first on PATH: ${forge_path}"
    echo -e "       ${MUTED}forge (the generator) is at ${uv_bin}/forge — put that dir ahead on PATH${NC}"
    ;;
esac

# -- Done ---------------------------------------------------------------------

echo -e ""
echo -e "  ${GREEN}Done!${NC} forge is ready."
echo -e ""
echo -e "  To get started, run:"
echo -e ""
echo -e "    ${GREEN}forge${NC}"
echo -e ""
echo -e "  ${MUTED}Then follow the prompts to generate your project.${NC}"
echo -e "  ${MUTED}For more info: https://github.com/cchifor/forge${NC}"
echo -e ""
