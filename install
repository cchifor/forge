#!/usr/bin/env bash
set -euo pipefail

REPO="https://github.com/cchifor/forge-cli.git"
TOOL="git+${REPO}"

MUTED='\033[0;2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
WARN='\033[38;5;214m'
NC='\033[0m'

# -- OS detection -------------------------------------------------------------

raw_os=$(uname -s)
case "$raw_os" in
  Darwin*)               os="macos" ;;
  Linux*)                os="linux" ;;
  MINGW*|MSYS*|CYGWIN*)  os="windows" ;;
  *)                     os="unknown" ;;
esac

# Detect WSL (reports Linux but is actually Windows)
if [[ "$os" == "linux" ]] && grep -qi microsoft /proc/version 2>/dev/null; then
  os="windows"
fi

# -- Helpers ------------------------------------------------------------------

installed() {
  command -v "$1" &>/dev/null
}

ps_exec() {
  powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$1"
}

get_version() {
  "$@" 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+[.0-9]*' | head -1
}

spin() {
  local pid=$1
  local msg=$2
  local frames=('/' '-' '\' '|')
  local i=0
  # Hide cursor
  printf "\033[?25l"
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${MUTED}[%s]${NC} %s" "${frames[i]}" "$msg"
    i=$(( (i + 1) % ${#frames[@]} ))
    sleep 0.15
  done
  wait "$pid" 2>/dev/null
  local ret=$?
  # Show cursor
  printf "\033[?25h"
  if [ $ret -eq 0 ]; then
    printf "\r  ${GREEN}[ok]${NC} %-40s\n" "$msg"
  else
    printf "\r  ${RED}[!!]${NC} %-40s\n" "$msg failed"
  fi
  return $ret
}

# -- Banner -------------------------------------------------------------------

echo -e ""
echo -e "  +===================================+"
echo -e "  |        ${NC}forge installer${MUTED}             |${NC}"
echo -e "  +===================================+"
echo -e ""
echo -e "  ${MUTED}Detected OS:${NC} $os"
echo -e ""

# -- uv (REQUIRED) -----------------------------------------------------------

if installed uv; then
  echo -e "  ${GREEN}[ok]${NC} uv $(get_version uv --version)"
else
  if [[ "$os" == "windows" ]]; then
    ps_exec "irm https://astral.sh/uv/install.ps1 | iex" > /dev/null 2>&1 &
  else
    curl -LsSf https://astral.sh/uv/install.sh | sh > /dev/null 2>&1 &
  fi
  spin $! "Installing uv..." || {
    echo -e "  ${RED}[!!] Cannot continue without uv. Aborting.${NC}"
    exit 1
  }
  # Refresh PATH
  if [[ "$os" == "windows" ]]; then
    eval "$(powershell.exe -NoProfile -Command '
      $p = [System.Environment]::GetEnvironmentVariable("Path","User") + ";" +
           [System.Environment]::GetEnvironmentVariable("Path","Machine")
      $p -split ";" | ForEach-Object { if ($_) { "export PATH=\"" + ($_ -replace "\\\\","/") + ":\$PATH\"" } }
    ')" 2>/dev/null || true
  else
    source "$HOME/.local/bin/env" 2>/dev/null || export PATH="$HOME/.local/bin:$PATH"
  fi
  if ! installed uv; then
    echo -e "  ${RED}[!!] uv not found on PATH after install. Aborting.${NC}"
    exit 1
  fi
fi

# -- git (recommended) -------------------------------------------------------

if installed git; then
  echo -e "  ${GREEN}[ok]${NC} git $(get_version git --version)"
else
  echo -e "  ${WARN}[--]${NC} git not found ${MUTED}(needed for project generation)${NC}"
  case "$os" in
    macos)
      echo -e "       ${MUTED}Run:${NC} xcode-select --install" ;;
    linux)
      echo -e "       ${MUTED}Run:${NC} sudo apt install git ${MUTED}(or your distro equivalent)${NC}" ;;
    windows)
      echo -e "       ${MUTED}Run:${NC} winget install Git.Git" ;;
  esac
fi

# -- docker (recommended) ----------------------------------------------------

if installed docker; then
  echo -e "  ${GREEN}[ok]${NC} docker $(get_version docker --version)"
else
  echo -e "  ${WARN}[--]${NC} docker not found ${MUTED}(needed to run the generated stack)${NC}"
  case "$os" in
    macos|windows)
      echo -e "       ${MUTED}Download:${NC} https://docker.com/products/docker-desktop" ;;
    linux)
      echo -e "       ${MUTED}Run:${NC} curl -fsSL https://get.docker.com | sh" ;;
  esac
fi

echo -e ""

# -- Install forge-cli --------------------------------------------------------

if [[ "$os" == "windows" ]]; then
  ps_exec "uv tool install $TOOL" > /dev/null 2>&1 &
else
  uv tool install "$TOOL" > /dev/null 2>&1 &
fi
spin $! "Installing forge-cli..." || {
  echo -e "  ${RED}[!!] Installation failed. Aborting.${NC}"
  exit 1
}

# -- Done ---------------------------------------------------------------------

echo -e ""
echo -e "  ${GREEN}Done!${NC} forge-cli is ready."
echo -e ""
echo -e "  To get started, open a new terminal and run:"
echo -e ""
echo -e "    ${GREEN}forge${NC}"
echo -e ""
echo -e "  ${MUTED}Then follow the prompts to generate your project.${NC}"
echo -e "  ${MUTED}For more info: https://github.com/cchifor/forge-cli${NC}"
echo -e ""
