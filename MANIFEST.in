# Include every shipped template file under forge/templates/ …
recursive-include forge/templates *

# Built-in feature subpackages colocate template trees alongside their
# Python registration modules (forge/features/<name>/templates/). Same
# convention third-party plugins use; same exclusion rules apply.
recursive-include forge/features *

# … except ephemeral caches + build output that occasionally end up in the
# working tree and would otherwise leak into the sdist/wheel. Epic DD's
# tests/test_package_integrity.py enforces the same exclusion list against
# the built artefacts — keep these two in sync when adding entries.
#
# Note: MANIFEST.in fnmatch patterns don't honor `**`; `*` doesn't cross
# directory separators. To exclude cache dirs at arbitrary depth we use
# `prune` (recursive) and additionally global-exclude entries below.
prune **/__pycache__
prune **/.mypy_cache
prune **/.ruff_cache
prune **/.pytest_cache
prune **/node_modules
prune **/.venv
prune **/htmlcov
prune **/.next
prune **/.svelte-kit
prune **/.dart_tool
# Cargo target/ from the auth Rust SDK's cross-SDK parity gate. Without
# this, `uv build` times out at 5 min trying to enumerate the target/
# tree (esp. on Windows MAX_PATH). Keep in sync with the matching
# [tool.setuptools.exclude-package-data] entry in pyproject.toml.
prune **/target
# Stray local build outputs under template subdirs (legacy entries kept
# for parity with templates).
recursive-exclude forge/templates */dist/*
recursive-exclude forge/templates */build/*
recursive-exclude forge/features */dist/*
recursive-exclude forge/features */build/*
global-exclude *.pyc *.pyo .DS_Store
